# Copy to .env.local and fill in your values. Vars prefixed VITE_ are compiled
# into the client bundle — they must only ever hold PUBLIC values.

# --- Site identity (SEO) ------------------------------------------------------
# Canonical production origin — used for <link rel=canonical>, OpenGraph URLs,
# hreflang alternates, sitemap.xml and robots.txt. No trailing slash.
# REQUIRED in production; the build warns loudly if missing or example.com.
VITE_SITE_URL=https://example.com
VITE_SITE_NAME=Manila Tour

# --- Supabase (public client) -------------------------------------------------
# Both are safe to expose in client code (the anon key is protected by RLS).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-only secrets — NEVER prefix with VITE_ ----------------------------
# Used only by trusted server-side tooling (scripts/seed.mjs). The sitemap
# generator deliberately uses the anon key (all its reads are public via RLS),
# so deployments don't need this at build time. Keep it out of git and out of
# any VITE_ variable.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI post assistant (Edge Function secret — NOT read by the frontend) -----
# Set with `supabase secrets set GEMINI_API_KEY=...` (Dashboard → Edge Functions
# → Secrets works too). Never put this in a VITE_ variable — the Edge Function
# at supabase/functions/ai-assistant is the only thing that reads it.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Misc ----------------------------------------------------------------------
# URL of the sister PhilGo deployment (the TopBar toggle).
# Leave unset in local dev (falls back to http://localhost:5175).
VITE_SISTER_SITE_URL=https://your-philgo-deployment.vercel.app
