{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    // A referenced project may not set noEmit (TS6310), and composite requires
    // declaration emit — so send the output somewhere untracked instead of
    // letting vite.config.js/.d.ts land next to vite.config.ts.
    "outDir": "./node_modules/.tmp/tsconfig-node"
  },
  "include": ["vite.config.ts"]
}
