{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path((?!assets/).*)",
      "has": [{ "type": "host", "value": "manilatour.com" }],
      "destination": "https://hanin.tv/:path",
      "permanent": false
    },
    {
      "source": "/:path((?!assets/).*)",
      "has": [{ "type": "host", "value": "www.manilatour.com" }],
      "destination": "https://hanin.tv/:path",
      "permanent": false
    },
    {
      "source": "/robots.txt",
      "has": [{ "type": "host", "value": "hanin.tv" }],
      "destination": "/robots.hanin.txt",
      "permanent": true
    },
    {
      "source": "/robots.txt",
      "has": [{ "type": "host", "value": "www.hanin.tv" }],
      "destination": "/robots.hanin.txt",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "has": [{ "type": "host", "value": "hanin.tv" }],
      "destination": "/sitemap.hanin.xml",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "has": [{ "type": "host", "value": "www.hanin.tv" }],
      "destination": "/sitemap.hanin.xml",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
